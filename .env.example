# Copy this file to .env and fill in your own API credentials.
# .env is gitignored — never commit real keys.
# Real shell / CI environment variables take precedence over this file.

# Reed (https://www.reed.co.uk/developers) — single API key, used with Basic auth.
REED_API_KEY=

# Adzuna (https://developer.adzuna.com/) — application id + key pair.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
